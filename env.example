/**
 * ╔══════════════════════════════════════════════════════════╗
 * ║  server.js — Express.js Backend Entry Point              ║
 * ║  Handles: REST API for database, AI chat proxy,          ║
 * ║  CORS, error handling, and static file serving.          ║
 * ║                                                          ║
 * ║  START:  node server.js   (or: npm start)                ║
 * ║  PORT:   3001 (configurable via PORT env var)            ║
 * ╚══════════════════════════════════════════════════════════╝
 */

'use strict';

const express    = require('express');
const cors       = require('cors');
const helmet     = require('helmet');
const rateLimit  = require('express-rate-limit');
const path       = require('path');
require('dotenv').config();  // Load .env variables

/* ── Route Handlers ────────────────────────────────────── */
const entriesRouter   = require('./routes/entries');
const booksRouter     = require('./routes/books');
const chatRouter      = require('./routes/chat');
const categoriesRouter = require('./routes/categories');

const app  = express();
const PORT = process.env.PORT || 3001;


/* ══════════════════════════════════════════════════════════
 * MIDDLEWARE STACK
 * ══════════════════════════════════════════════════════════ */

/* Security headers via helmet */
app.use(helmet({
  contentSecurityPolicy: false,  // Disabled to allow external fonts/scripts in dev
}));

/* CORS: Allow frontend origin in dev, restrict in production */
app.use(cors({
  origin: process.env.NODE_ENV === 'production'
    ? process.env.FRONTEND_URL  // e.g. 'https://bengalislamic.org'
    : ['http://localhost:3000', 'http://127.0.0.1:5500', 'null'],
  methods:  ['GET', 'POST', 'PUT', 'DELETE'],
  allowedHeaders: ['Content-Type', 'Authorization']
}));

/* Parse JSON and URL-encoded bodies */
app.use(express.json({ limit: '1mb' }));
app.use(express.urlencoded({ extended: true, limit: '1mb' }));

/* Rate limiting — protects API from abuse */
const apiLimiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max:      100,              // 100 requests per window per IP
  message: { error: 'Too many requests. Please try again later.' }
});

/* Stricter limit on the AI chat endpoint (costs money!) */
const chatLimiter = rateLimit({
  windowMs: 60 * 1000, // 1 minute
  max:      10,         // 10 messages/minute per IP
  message:  { error: 'Chat rate limit reached. Please wait a moment.' }
});

/* ── Serve static frontend files ─────────────────────── */
app.use(express.static(path.join(__dirname, '../frontend')));


/* ══════════════════════════════════════════════════════════
 * API ROUTES
 * All routes prefixed with /api/
 * ══════════════════════════════════════════════════════════ */
app.use('/api',          apiLimiter);
app.use('/api/entries',  entriesRouter);
app.use('/api/books',    booksRouter);
app.use('/api/chat',     chatLimiter, chatRouter);
app.use('/api/categories', categoriesRouter);

/* Health check endpoint (useful for deployment monitoring) */
app.get('/api/health', (req, res) => {
  res.json({
    status:    'OK',
    timestamp: new Date().toISOString(),
    version:   process.env.npm_package_version || '1.0.0'
  });
});


/* ══════════════════════════════════════════════════════════
 * SPA FALLBACK
 * Serve index.html for all non-API routes so client-side
 * routing works correctly after deployment.
 * ══════════════════════════════════════════════════════════ */
app.get('*', (req, res) => {
  if (!req.path.startsWith('/api')) {
    res.sendFile(path.join(__dirname, '../frontend/index.html'));
  }
});


/* ══════════════════════════════════════════════════════════
 * GLOBAL ERROR HANDLER
 * Catches any unhandled errors from routes/middleware.
 * ══════════════════════════════════════════════════════════ */
// eslint-disable-next-line no-unused-vars
app.use((err, req, res, next) => {
  console.error('[Server Error]', err.stack);
  res.status(err.status || 500).json({
    error:   err.message || 'Internal server error',
    path:    req.path,
    ...(process.env.NODE_ENV !== 'production' && { stack: err.stack })
  });
});


/* ── START SERVER ───────────────────────────────────────── */
app.listen(PORT, () => {
  console.log(`\n✅ Bengal Islamic Heritage Server`);
  console.log(`   Port:     ${PORT}`);
  console.log(`   API:      http://localhost:${PORT}/api`);
  console.log(`   Frontend: http://localhost:${PORT}`);
  console.log(`   Env:      ${process.env.NODE_ENV || 'development'}\n`);
});

module.exports = app; // For testing
